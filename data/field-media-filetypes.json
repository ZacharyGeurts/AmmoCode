{
  "schema": "field-media-filetypes/v1",
  "title": "AmmoOS clipboard & vault — all media eras",
  "motto": "Amiga IFF · PCX every variant · DOS · Atari · Mac · we do them all",
  "clipboard": {
    "accept_all_registered": true,
    "max_bytes": 67108864,
    "ring_max": 16
  },
  "families": {
    "amiga": {
      "label": "Commodore Amiga",
      "era": "1985-1994",
      "formats": ["iff_ilbm", "iff_anim", "iff_8svx", "iff_smus", "amiga_mod", "amiga_disk", "amiga_font", "amiga_icon"]
    },
    "dos_pcx": {
      "label": "PC Paintbrush / ZSoft PCX lineage",
      "era": "1982-1996",
      "formats": ["pcx", "pcx_vga", "pcx_ega", "pcx_cga", "pcx_mono", "dcx"]
    },
    "dos_graphics": {
      "label": "DOS & BBS graphics",
      "era": "1981-1999",
      "formats": ["bmp", "gif", "tga", "cel", "pic", "wpg", "gem_img", "ansi_art", "nfo_art"]
    },
    "atari_st": {
      "label": "Atari ST / NeoChrome / Degas",
      "era": "1985-1993",
      "formats": ["neochrome", "degas_pi", "tny", "tiny"]
    },
    "mac_classic": {
      "label": "Classic Macintosh",
      "era": "1984-1998",
      "formats": ["macpaint", "pict", "icns"]
    },
    "tracker": {
      "label": "Tracker modules (Amiga · PC)",
      "era": "1987-2000",
      "formats": ["amiga_mod", "xm", "s3m", "it", "669", "med", "okt", "mtm", "stm", "far", "amf"]
    },
    "modern_raster": {
      "label": "Modern raster",
      "formats": ["png", "jpeg", "webp", "avif", "heic", "tiff", "svg", "psd"]
    },
    "modern_video": {
      "label": "Video containers",
      "formats": ["mp4", "webm", "mkv", "avi", "mov", "ogv", "m4v", "wmv", "flv", "mpg"]
    },
    "modern_audio": {
      "label": "Audio",
      "formats": ["wav", "mp3", "ogg", "flac", "aac", "m4a", "aiff", "mid", "midi"]
    },
    "archive": {
      "label": "Archives (clipboard file payloads)",
      "formats": ["zip", "lha", "lzx", "gz", "tar", "7z", "rar"]
    }
  },
  "formats": {
    "iff_ilbm": {
      "label": "IFF ILBM — interleaved bitmap",
      "family": "amiga",
      "mime": "image/x-iff",
      "kind": "image",
      "variants": ["std", "ham", "ham6", "ham8", "ehb", "deep", "24bit", "ham10"],
      "extensions": [".iff", ".ilbm", ".lbm"],
      "clipboard": true,
      "notes": "Deluxe Paint Amiga · Brilliance · Photon Paint"
    },
    "iff_anim": {
      "label": "IFF ANIM / ANBM animation",
      "family": "amiga",
